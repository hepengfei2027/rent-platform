<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.OrderDao">

    <resultMap id="OrderResultMap" type="com.model.Order">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="productId" column="product_id"/>
        <result property="productName" column="product_name"/>
        <result property="buyerId" column="buyer_id"/>
        <result property="buyerName" column="buyer_name"/>
        <result property="sellerId" column="seller_id"/>
        <result property="sellerName" column="seller_name"/>
        <result property="amount" column="amount"/>
        <result property="orderType" column="order_type"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="rentStartTime" column="rent_start_time"/>
        <result property="rentEndTime" column="rent_end_time"/>
        <result property="rentDays" column="rent_days"/>



    </resultMap>

    <insert id="insert" parameterType="com.model.Order" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `order` (
        order_no, product_id, product_name, buyer_id, buyer_name,
        seller_id, seller_name, amount, order_type, status, create_time,
        <!-- ✅ 新增租赁字段 -->
        rent_days, rent_start_time, rent_end_time
        ) VALUES (
        #{orderNo}, #{productId}, #{productName}, #{buyerId}, #{buyerName},
        #{sellerId}, #{sellerName}, #{amount}, #{orderType}, #{status}, NOW(),
        <!-- ✅ 新增租赁参数 -->
        #{rentDays}, #{rentStartTime}, #{rentEndTime}
        )
    </insert>

    <select id="findById" parameterType="int" resultMap="OrderResultMap">
        SELECT * FROM `order` WHERE id = #{id}
    </select>

    <select id="findByBuyerId" parameterType="int" resultMap="OrderResultMap">
        SELECT * FROM `order` WHERE buyer_id = #{buyerId} ORDER BY create_time DESC
    </select>

    <update id="updateStatus">
        UPDATE `order` SET status = #{status} WHERE id = #{id}
    </update>

    <!-- 统计全平台交易总额 -->
    <select id="getTotalTransactionAmount" resultType="java.lang.Double">
        SELECT COALESCE(SUM(amount), 0) FROM `order` WHERE status IN (1, 2, 3)
    </select>

</mapper>